run = "npm install && npm run start"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_11"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 8082
externalPort = 3001

[env]
CI = "1"
EXPO_NO_DOTENV = "1"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npx expo start --port 3000 --non-interactive"
waitForPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["node", "serve.js"]
