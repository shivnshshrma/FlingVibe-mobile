{
  "expo": {
    "name": "fling vibe",
    "slug": "flingvibe",
    "privacy": "public",
    "description": "Account sharing platform",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shivnshshrmasorganization.flingvibe",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.shivnshshrmasorganization.flingvibe"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FlingVibe to access your camera for video chats.",
          "microphonePermission": "Allow FlingVibe to access your microphone for voice chats.",
          "recordAudioAndroid": true
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "11ef7ede-8808-415b-a43d-dfb454e36513"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/11ef7ede-8808-415b-a43d-dfb454e36513"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "owner": "shivnshshrma"
  }
}
